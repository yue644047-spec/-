# ============================================
# 敏感信息配置文件 (Secrets)
# ============================================
# ⚠️ 警告: 此文件包含敏感信息 (API Keys, Tokens)
# ============================================
# 安全建议:
#   1. 此文件不应提交到 Git 仓库
#   2. 不要分享此文件给其他人
#   3. 部署到生产环境时, 使用环境变量或密钥管理服务
# ============================================

# ============================================
# LLM API 配置 (DeepSeek / OpenAI 等)
# ============================================
# DeepSeek API
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=deepseek-chat

# OpenAI API (备用)
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# 抖音 Cookie (敏感凭证)
# ============================================
# 获取方式: 浏览器访问对应页面 → F12 → Network → 复制 Cookie
DOUYIN_COOKIE=你的www.douyin.com_Cookie值
LIVE_COOKIE=你的live.douyin.com_Cookie值

# ============================================
# 第三方服务密钥 (如需要)
# ============================================
# 数据分析服务
# ANALYTICS_API_KEY=your_analytics_key

# 消息推送服务 (钉钉/飞书/微信)
# WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_token

# 数据库密码 (如使用)
# DATABASE_PASSWORD=your_db_password
