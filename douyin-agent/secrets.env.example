# ============================================
# 敏感信息配置文件模板 (Secrets Template)
# ============================================
# ⚠️ 警告: 此文件包含敏感信息 (API Keys, Tokens)
# ============================================
# 使用方法:
#   1. 复制此文件为 secrets.env
#   2. 填入你真实的配置信息
#   3. 不要把 secrets.env 提交到 Git 仓库
# ============================================

# ============================================
# LLM API 配置 (DeepSeek / OpenAI 等)
# ============================================
# DeepSeek API (推荐)
LLM_API_KEY=sk-your_deepseek_api_key_here
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat

# OpenAI API (备用, 如需要)
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# 抖音 Cookie (敏感凭证)
# ============================================
# 获取方式:
#   1. 浏览器访问对应页面
#   2. 按 F12 打开开发者工具
#   3. 切换到 Network 标签
#   4. 找到任意请求, 复制 Cookie 值
DOUYIN_COOKIE=your_www_douyin_cookie_here
LIVE_COOKIE=your_live_douyin_cookie_here

# ============================================
# 第三方服务密钥 (按需启用)
# ============================================
# 数据分析服务
# ANALYTICS_API_KEY=your_analytics_key

# 消息推送服务 (钉钉/飞书/企业微信)
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 数据库密码 (如使用外部数据库)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_PASSWORD=your_db_password
